{
  "skill_name": "lessons",
  "evals": [
    {
      "id": 1,
      "prompt": "파이썬 스크립트를 실행하려고 했는데 네가 bash 명령어를 `echo 'print(1)' > script.py && python script.py` 이렇게 작성해줬어. 근데 틀렸어 - Write tool을 써야 했는데. 기록해줘.",
      "expected_output": "mistakes.md에 날짜 | 컨텍스트, 실수, 교정 형식으로 기록되고, 사용자에게 기록 완료를 한 줄로 알린다",
      "files": [],
      "assertions": [
        {
          "id": "e1-a1",
          "text": "mistakes_md.txt 파일이 존재하고 비어있지 않다",
          "check": "file_exists_and_nonempty"
        },
        {
          "id": "e1-a2",
          "text": "날짜 헤더 형식(## YYYY-MM-DD |)이 포함됐다",
          "check": "regex_in_mistakes_md"
        },
        {
          "id": "e1-a3",
          "text": "'실수:' 필드가 기록됐다",
          "check": "text_in_mistakes_md"
        },
        {
          "id": "e1-a4",
          "text": "'교정:' 필드가 기록됐다",
          "check": "text_in_mistakes_md"
        },
        {
          "id": "e1-a5",
          "text": "응답이 간결하다 (5줄 이내 완료 알림)",
          "check": "response_line_count"
        }
      ]
    },
    {
      "id": 2,
      "prompt": "/lessons",
      "expected_output": "mistakes.md 파일을 읽고 실수 목록을 날짜순으로 요약해서 보여준다. 파일이 없으면 '아직 기록된 실수가 없습니다'를 출력한다.",
      "files": [],
      "assertions": [
        {
          "id": "e2-a1",
          "text": "3개의 실수 항목(날짜)을 모두 언급했다",
          "check": "contains_all_dates"
        },
        {
          "id": "e2-a2",
          "text": "반복 패턴(설치 경로 실수가 2번)을 명시적으로 강조했다",
          "check": "pattern_highlighted"
        },
        {
          "id": "e2-a3",
          "text": "날짜 오름차순(03-20, 03-22, 03-24)으로 정렬됐다",
          "check": "chronological_order"
        }
      ]
    },
    {
      "id": 3,
      "prompt": "그게 아니야. 스킬 설치 경로가 ~/.claude/skills/ 가 아니라 ~/.claude/commands/ 야. 스킬은 commands 디렉토리에 설치하는 거야.",
      "expected_output": "사용자 교정 발언을 감지해서 자동으로 mistakes.md에 기록하고 기록 완료를 알린다",
      "files": [],
      "assertions": [
        {
          "id": "e3-a1",
          "text": "교정 트리거('그게 아니야')를 감지하고 실수를 기록했다",
          "check": "mistakes_md_has_new_entry"
        },
        {
          "id": "e3-a2",
          "text": "올바른 경로(commands)가 교정으로 기록됐다",
          "check": "commands_in_mistakes_md"
        },
        {
          "id": "e3-a3",
          "text": "사용자에게 기록 완료를 알렸다",
          "check": "completion_notice_in_response"
        }
      ]
    }
  ]
}
